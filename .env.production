PORT=3000
HOST=0.0.0.0
APP_BASE_URL=https://api.cloudagi.org
ADMIN_KEY=<generated>
CORS_ORIGIN=https://cloudagi.org

# Nevermined
NVM_API_KEY=<user-provided>
NVM_ENVIRONMENT=<sandbox-or-production>
NVM_AGENT_ID=<user-provided>
NVM_PLAN_ID=<user-provided>
NVM_BUILDER_ADDRESS=<user-provided>
NVM_USDC_ADDRESS=<user-provided>

# Modal (only needed if no ~/.modal.toml on VPS)
MODAL_TOKEN_ID=<if-needed>
MODAL_TOKEN_SECRET=<if-needed>
