# === Server ===
PORT=3000
HOST=0.0.0.0
APP_BASE_URL=https://api.cloudagi.org
ADMIN_KEY=<generated>
CORS_ORIGIN=https://cloudagi.org

# === Nevermined ===
NVM_API_KEY=<from-nevermined-app>
NVM_ENVIRONMENT=sandbox
NVM_PAYMENT_RAIL=fiat
NVM_AGENT_ID=<from-register-all-services>
NVM_PLAN_ID=<from-register-all-services>
NVM_BUILDER_ADDRESS=<your-wallet-address>
NVM_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Per-service Nevermined IDs (output of `bun run register:all-services`)
NVM_GPU_COMPUTE_AGENT_ID=<from-register-all-services>
NVM_GPU_COMPUTE_PLAN_ID=<from-register-all-services>
NVM_AI_RESEARCH_AGENT_ID=<from-register-all-services>
NVM_AI_RESEARCH_PLAN_ID=<from-register-all-services>
NVM_WEB_SCRAPER_AGENT_ID=<from-register-all-services>
NVM_WEB_SCRAPER_PLAN_ID=<from-register-all-services>
NVM_CODE_REVIEW_AGENT_ID=<from-register-all-services>
NVM_CODE_REVIEW_PLAN_ID=<from-register-all-services>
NVM_SMART_SEARCH_AGENT_ID=<from-register-all-services>
NVM_SMART_SEARCH_PLAN_ID=<from-register-all-services>
NVM_ORCHESTRATOR_AGENT_ID=<from-register-all-services>
NVM_ORCHESTRATOR_PLAN_ID=<from-register-all-services>

# === Pricing ===
CLOUDAGI_OFFER_NAME=CloudAGI Fast Run
CLOUDAGI_PRICE_AMOUNT=25
CLOUDAGI_PAYMENT_CURRENCY=USD
CLOUDAGI_PRICE_LABEL=25 USD
CLOUDAGI_PRICE_UNITS=2500
CLOUDAGI_PLAN_CREDITS=1

# === Modal (only needed if no ~/.modal.toml on VPS) ===
MODAL_APP_NAME=cloudagi
MODAL_IMAGE=python:3.13
MODAL_ENVIRONMENT_NAME=main
MODAL_GPU=none
MODAL_TIMEOUT_SECS=1800
# MODAL_TOKEN_ID=<if-needed>
# MODAL_TOKEN_SECRET=<if-needed>

# === Trinity ===
TRINITY_BASE_URL=<your-trinity-url>
TRINITY_API_KEY=<your-trinity-key>
TRINITY_SYSTEM_NAME=cloudagi-fixed-system
TRINITY_ORCHESTRATOR_AGENT=orchestrator
TRINITY_SHARED_SECRET=<generated>

# === Sponsor API Keys ===
EXA_API_KEY=<from-exa-ai>
APIFY_API_TOKEN=<from-apify-com>
ANTHROPIC_API_KEY=<from-anthropic>
