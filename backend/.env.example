# === Server ===
PORT=3000
HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000
ADMIN_KEY=change-me
CORS_ORIGIN=*

# === Modal (GPU Compute) ===
MODAL_APP_NAME=cloudagi
MODAL_IMAGE=python:3.13
MODAL_ENVIRONMENT_NAME=main
MODAL_GPU=none
MODAL_TIMEOUT_SECS=1800
# Modal auth (for Docker; on host use `modal token set`)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# === Trinity (Orchestration) ===
TRINITY_BASE_URL=
TRINITY_API_KEY=
TRINITY_SYSTEM_NAME=cloudagi-fixed-system
TRINITY_ORCHESTRATOR_AGENT=orchestrator
TRINITY_SHARED_SECRET=

# === Nevermined (Payments & Marketplace) ===
NVM_API_KEY=
NVM_ENVIRONMENT=sandbox
NVM_PAYMENT_RAIL=crypto
NVM_AGENT_ID=
NVM_PLAN_ID=
NVM_BUILDER_ADDRESS=
NVM_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Per-service Nevermined agent/plan IDs (output of `bun run register:all-services`)
# Leave blank to use the default NVM_AGENT_ID/NVM_PLAN_ID for all services
NVM_GPU_COMPUTE_AGENT_ID=
NVM_GPU_COMPUTE_PLAN_ID=
NVM_AI_RESEARCH_AGENT_ID=
NVM_AI_RESEARCH_PLAN_ID=
NVM_WEB_SCRAPER_AGENT_ID=
NVM_WEB_SCRAPER_PLAN_ID=
NVM_CODE_REVIEW_AGENT_ID=
NVM_CODE_REVIEW_PLAN_ID=
NVM_SMART_SEARCH_AGENT_ID=
NVM_SMART_SEARCH_PLAN_ID=

# === Pricing (for legacy order flow) ===
CLOUDAGI_OFFER_NAME=CloudAGI
CLOUDAGI_PRICE_AMOUNT=25
CLOUDAGI_PAYMENT_CURRENCY=USDC
CLOUDAGI_PRICE_LABEL=25 USDC
CLOUDAGI_PRICE_UNITS=25000000
CLOUDAGI_PLAN_CREDITS=1

# === Sponsor API Keys ===
EXA_API_KEY=
APIFY_API_TOKEN=
ANTHROPIC_API_KEY=

# === OpenRouter (alternative LLM provider, used for Code Review) ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
